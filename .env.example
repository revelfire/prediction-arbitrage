# PostgreSQL (used by both the db container and the app)
POSTGRES_USER=arb_scanner
POSTGRES_PASSWORD=changeme
POSTGRES_DB=arb_scanner
POSTGRES_PORT=5432

# App database URL (references the db service from docker-compose)
DATABASE_URL=postgresql://arb_scanner:changeme@db:5432/arb_scanner

# Claude API (required for semantic contract matching)
ANTHROPIC_API_KEY=

# Voyage AI (only needed if config.yaml sets embedding.provider to "voyage")
# VOYAGE_API_KEY=

# Scanner interval in seconds (default 60)
SCAN_INTERVAL=60

# Notifications (optional — leave empty to disable)
ARBITRAGE_SLACK_WEBHOOK_URL=
FLIPPENING_SLACK_WEBHOOK_URL=
AUTO_EXEC_SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# Dashboard auth (optional — set to require bearer token for dashboard access)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# DASHBOARD_AUTH_TOKEN=

# One-click execution (optional — see docs/wallet-setup.md)
# Polymarket: Polygon wallet private key (hex, with 0x prefix)
POLY_PRIVATE_KEY=
# Signature mode: 0=EOA, 2=browser-wallet proxy accounts (method-2)
POLY_SIGNATURE_TYPE=0
# Required when POLY_SIGNATURE_TYPE!=0 (funded proxy/funder address)
POLY_FUNDER=
# Polymarket CLOB API credentials (Level 2 auth — required for balance & trading)
# Derive once: uv run python3 -c "
#   from py_clob_client.client import ClobClient
#   c = ClobClient('https://clob.polymarket.com', key='0xYOUR_KEY', chain_id=137)
#   print(c.derive_api_key())"
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=
# Kalshi: API key ID and path to RSA private key PEM file
KALSHI_API_KEY_ID=
# In Docker: /app/kalshi-key.pem (mounted via docker-compose volume)
# Local: relative or absolute path to your PEM file
KALSHI_RSA_PRIVATE_KEY_PATH=
